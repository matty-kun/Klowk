{
  "expo": {
    "name": "Flow",
    "slug": "flow",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flow",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBBF24"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png"
      },
      "minSdkVersion": 24,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "io.flow.app",
      "versionCode": 4
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withNotifee",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Flow to save session cards to your photos.",
          "savePhotosPermission": "Allow Flow to save session cards to your photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Flow to access your photos for session cards.",
          "cameraPermission": "Allow Flow to use your camera for session cards."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "FocusWidget",
              "label": "Flow – Focus Tracker",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "See today's focus time and streak at a glance",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
