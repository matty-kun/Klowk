{
  "expo": {
    "name": "Flow",
    "slug": "flow",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBBF24"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png"
      },
      "minSdkVersion": 24,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "io.flow.app",
      "versionCode": 12,
      "launchMode": "singleTask",
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Flow to use your camera for session cards."
        }
      ],
      "./plugins/withNotifee",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Flow to save session cards to your photos.",
          "savePhotosPermission": "Allow Flow to save session cards to your photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Flow to access your photos for session cards.",
          "cameraPermission": "Allow Flow to use your camera for session cards."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "FocusWidget",
              "label": "Flow – Today's Focus",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Today's focus time with a quick start button",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "StreakWidget",
              "label": "Flow – Streak",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Your current streak and weekly activity",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b832990-a2d8-480d-b0fa-7de0eb91ec00"
      }
    }
  }
}
